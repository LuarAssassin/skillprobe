{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skill_profile.schema.json",
  "title": "SkillProfile",
  "description": "Skill 的结构化能力画像",
  "type": "object",
  "required": ["id", "name", "description", "problem_domain", "source"],
  "properties": {
    "id": { "type": "string", "description": "唯一标识符" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string", "default": "0.0.0" },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["local", "git", "clawhub"] },
        "path": { "type": "string" },
        "url": { "type": "string" },
        "commit": { "type": "string" }
      },
      "required": ["type"]
    },
    "problem_domain": {
      "type": "array",
      "items": { "type": "string" },
      "description": "skill 目标解决的问题域"
    },
    "trigger_conditions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "skill 触发条件描述"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "skill 提供的能力列表"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "tools": { "type": "array", "items": { "type": "string" } },
        "models": { "type": "array", "items": { "type": "string" } },
        "data_sources": { "type": "array", "items": { "type": "string" } }
      }
    },
    "boundaries": {
      "type": "object",
      "properties": {
        "applicable": { "type": "array", "items": { "type": "string" } },
        "not_applicable": { "type": "array", "items": { "type": "string" } }
      },
      "description": "适用与不适用边界"
    },
    "content_summary": { "type": "string", "description": "skill 内容摘要" },
    "rule_count": { "type": "integer" },
    "file_count": { "type": "integer" },
    "total_tokens_estimate": { "type": "integer" },
    "profiled_at": { "type": "string", "format": "date-time" }
  }
}
