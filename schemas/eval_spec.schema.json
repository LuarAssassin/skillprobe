{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "eval_spec.schema.json",
  "title": "EvalSpec",
  "description": "评测计划规格",
  "type": "object",
  "required": ["id", "skill_profile_id", "task_domain", "metrics", "baseline_config", "skill_config"],
  "properties": {
    "id": { "type": "string" },
    "skill_profile_id": { "type": "string" },
    "task_domain": {
      "type": "array",
      "items": { "type": "string" },
      "description": "测试任务域"
    },
    "test_objectives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "task_categories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "count": { "type": "integer" },
          "difficulty_distribution": {
            "type": "object",
            "properties": {
              "easy": { "type": "number" },
              "medium": { "type": "number" },
              "hard": { "type": "number" },
              "edge": { "type": "number" }
            }
          }
        },
        "required": ["name", "count"]
      }
    },
    "baseline_config": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "system_prompt": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "timeout_seconds": { "type": "integer" },
        "seed": { "type": "integer" }
      },
      "required": ["model"]
    },
    "skill_config": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "system_prompt": { "type": "string" },
        "skill_content": { "type": "string", "description": "注入的 skill 内容" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "timeout_seconds": { "type": "integer" },
        "seed": { "type": "integer" }
      },
      "required": ["model", "skill_content"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "effectiveness_weight": { "type": "number", "default": 0.30 },
        "quality_weight": { "type": "number", "default": 0.20 },
        "efficiency_weight": { "type": "number", "default": 0.15 },
        "stability_weight": { "type": "number", "default": 0.15 },
        "trigger_fitness_weight": { "type": "number", "default": 0.10 },
        "safety_weight": { "type": "number", "default": 0.10 }
      }
    },
    "success_criteria": {
      "type": "object",
      "properties": {
        "min_net_gain": { "type": "number", "default": 3.0 },
        "max_regression_rate": { "type": "number", "default": 0.15 },
        "min_tasks": { "type": "integer", "default": 20 }
      }
    },
    "stopping_criteria": {
      "type": "object",
      "properties": {
        "max_failures": { "type": "integer", "default": 5 },
        "max_cost_usd": { "type": "number" },
        "max_duration_minutes": { "type": "integer" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
